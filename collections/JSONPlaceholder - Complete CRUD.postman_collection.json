{
  "info": {
    "_postman_id": "6610520f-8e41-4086-a64b-29423aac0318",
    "name": "JSONPlaceholder - Complete CRUD",
    "description": "This collection demonstrates the complete CRUD lifecycle for the JSONPlaceholder `/posts` resource. It includes requests to create a post, retrieve a specific post by ID, list all posts, fully update a post, partially update a post, delete a post, and verify the deletion.\n\nThe collection is organized as a simple end-to-end workflow for practicing REST API operations and understanding how different HTTP methods behave in a typical resource-based API. It also uses variables such as `{{baseURL}}` and `{{postID}}` to make requests reusable and easier to manage across environments.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "_exporter_id": "53774654",
    "_collection_link": "https://go.postman.co/collection/53774654-6610520f-8e41-4086-a64b-29423aac0318?source=collection_link"
  },
  "item": [
    {
      "name": "1- Create Post",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "// Status code 200, post created\r",
              "pm.test(\"Status code is 201, post is created successfully\", function () {\r",
              "    pm.response.to.have.status(201);\r",
              "    });\r",
              "\r",
              "// Body has required fields\r",
              "pm.test(\"Post contains id, title, body and userId\", function () {\r",
              "    var jsonData = pm.response.json();\r",
              "    pm.expect(jsonData).to.have.property('id');\r",
              "    pm.expect(jsonData).to.have.property('title');\r",
              "    pm.expect(jsonData).to.have.property('body');\r",
              "    pm.expect(jsonData).to.have.property('userId');\r",
              "    });\r",
              "\r",
              "// Check if the ID is a number and an integer.\r",
              "pm.test(\"ID is a number and an integer\", function () {\r",
              "    var jsonData = pm.response.json();\r",
              "    pm.expect(jsonData.id).to.be.a('number');\r",
              "    pm.expect(Number.isInteger(jsonData.id)).to.be.true;\r",
              "});\r",
              "\r",
              "// Save postId for future tests\r",
              "pm.test(\"Save postId for future tests\", function () {\r",
              "    pm.environment.set(\"postID\", pm.response.json().id);\r",
              "    });"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [],
        "body": {
          "mode": "raw",
          "raw": "{\r\n    \"title\": \"Test Post\",\r\n    \"body\": \"Post created via Postman\",\r\n    \"userId\": 1\r\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": {
          "raw": "{{baseURL}}/posts",
          "host": [
            "{{baseURL}}"
          ],
          "path": [
            "posts"
          ]
        },
        "description": "This request checks the Create workflow for the JSONPlaceholder `/posts` resource."
      },
      "response": []
    },
    {
      "name": "2- Search Post by ID",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "// Status code is 200\r",
              "pm.test(\"Status code is 200\", function () {\r",
              "    pm.response.to.have.status(200);\r",
              "    });\r",
              "\r",
              "// AJV use to validate JSON schema\r",
              "const AJV = require('ajv');\r",
              "const ajv = new AJV();\r",
              "const schema = {\r",
              "    type: \"object\",\r",
              "    required: [\"id\", \"title\", \"body\", \"userId\"],\r",
              "    properties: {\r",
              "        id: { type: \"integer\" },\r",
              "        title: { type: \"string\", minLenght: 1 },\r",
              "        body: { type: \"string\" },\r",
              "        userId: { type: \"integer\", minimun: 1 }\r",
              "        },\r",
              "    additionalProperties: false\r",
              "}\r",
              "\r",
              "const validate = ajv.compile(schema);\r",
              "const valid = validate(pm.response.json());\r",
              "\r",
              "pm.test(\"Response body is valid JSON\", function () {\r",
              "    pm.expect(valid).to.be.true;\r",
              "    });"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseURL}}/posts/{{postID}}",
          "host": [
            "{{baseURL}}"
          ],
          "path": [
            "posts",
            "{{postID}}"
          ]
        },
        "description": "This request checks if the post was created, checking the Read Workflow for a specific post"
      },
      "response": []
    },
    {
      "name": "3- List All Posts",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "// Status code is 200, posts returned\r",
              "pm.test(\"Status code is 200\", function () {\r",
              "    pm.response.to.have.status(200);\r",
              "    });\r",
              "\r",
              "// Has at least one post\r",
              "pm.test(\"Response has at least one post\", function () {\r",
              "    var jsonData = pm.response.json();\r",
              "    pm.expect(jsonData).to.be.an(\"array\");\r",
              "    pm.expect(jsonData.length).to.be.above(0);\r",
              "    });\r",
              "\r",
              "// First post has separated fields\r",
              "pm.test(\"First post has id, title, body, and userId\", function () {\r",
              "    pm.expect(pm.response.json()[0]).to.have.all.keys(\"id\", \"title\", \"body\", \"userId\");\r",
              "    });"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseURL}}/posts",
          "host": [
            "{{baseURL}}"
          ],
          "path": [
            "posts"
          ]
        },
        "description": "This request lists the posts in `/posts`, checking the Read Workflow for all of them"
      },
      "response": []
    },
    {
      "name": "4- Update Post",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "// Status Code is 200, Post Updated\r",
              "pm.test(\"Status code is 200\", function () {\r",
              "    pm.response.to.have.status(200);\r",
              "    });\r",
              "\r",
              "// Response Body contains the updated post\r",
              "pm.test(\"Response body contains the updated post\", function () {\r",
              "    var jsonData = pm.response.json();\r",
              "    pm.expect(jsonData.title).to.equal(\"Title Updated via PUT\"),\r",
              "    pm.expect(jsonData.body).to.equal(\"Body Updated via PUT\");\r",
              "    });"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "method": "PUT",
        "header": [],
        "body": {
          "mode": "raw",
          "raw": "{\r\n    \"id\": {{postID}},\r\n    \"title\": \"Title Updated via PUT\",\r\n    \"body\": \"Body Updated via PUT\",\r\n    \"userId\": 1\r\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": {
          "raw": "{{baseURL}}/posts/{{postID}}",
          "host": [
            "{{baseURL}}"
          ],
          "path": [
            "posts",
            "{{postID}}"
          ]
        },
        "description": "This request updates the created post, checking the Update Workflow"
      },
      "response": []
    },
    {
      "name": "5- Update Partially",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "// Response is 200, post is updated\r",
              "pm.test(\"Status code is 200\", function () {\r",
              "    pm.response.to.have.status(200);\r",
              "    });\r",
              "\r",
              "// Body contains a title field\r",
              "pm.test(\"Response body has a title field\", function () {\r",
              "    pm.expect(pm.response.json()).to.have.property(\"title\");\r",
              "});\r",
              "\r",
              "// Response body contains updated post information\r",
              "pm.test(\"Response body contains updated post information\", function () {\r",
              "    pm.expect(pm.response.json().title).to.equal(\"Title Modified via PATCH\");\r",
              "    });"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "method": "PATCH",
        "header": [],
        "body": {
          "mode": "raw",
          "raw": "{\r\n    \"title\": \"Title Modified via PATCH\"\r\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": {
          "raw": "{{baseURL}}/posts/{{postID}}",
          "host": [
            "{{baseURL}}"
          ],
          "path": [
            "posts",
            "{{postID}}"
          ]
        },
        "description": "This request updates the title of the created post, checking the Update Workflow for a single attribute"
      },
      "response": []
    },
